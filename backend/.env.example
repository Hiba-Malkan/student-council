# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration (PostgreSQL with psycopg3)
# Engine: django.db.backends.postgresql (works with psycopg-binary==3.3.2)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=student_council_db
# On macOS, PostgreSQL uses your system username by default (run 'whoami' to find it)
# On Linux, it's usually 'postgres'
DB_USER=hiba
# Leave password empty for local development on macOS, or set a password
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=600

# Use SQLite instead of PostgreSQL (set to True for development with SQLite)
USE_SQLITE=False

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Email Configuration (Gmail - Get App Password from https://myaccount.google.com/apppasswords)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password-here
DEFAULT_FROM_EMAIL=your-email@gmail.com

# Site URL (for email links)
SITE_URL=http://localhost:8000
